{% comment %}
  Section: Fiche produit véhicule - Vue principale
{% endcomment %}

<div class="product-main section">
  <div class="page-width">
    <div class="product-main__grid">
      <div class="product-main__gallery">
        {% if product.images.size > 0 %}
          <div class="product-main__image-main">
            {{ product.featured_image | image_url: width: 900 | image_tag: loading: 'eager', alt: product.title }}
          </div>
          {% if product.images.size > 1 %}
            <div class="product-main__thumbs">
              {% for image in product.images limit: 6 %}
                <button type="button" class="product-main__thumb {% if forloop.first %}active{% endif %}" data-src="{{ image | image_url: width: 900 }}">
                  {{ image | image_url: width: 150 | image_tag: loading: 'lazy', alt: product.title }}
                </button>
              {% endfor %}
            </div>
          {% endif %}
        {% else %}
          <div class="product-main__placeholder">🚗</div>
        {% endif %}
      </div>

      <div class="product-main__info">
        {% assign price_indicator = product.metafields.custom.price_indicator %}
        {% if price_indicator != blank %}
          <span class="product-main__badge">{{ price_indicator }}</span>
        {% endif %}

        <h1 class="product-main__title">{{ product.title }}</h1>
        <p class="product-main__price">{{ product.price | money }}</p>

        <div class="product-main__specs">
          {% if product.metafields.custom.year %}
            <div class="product-main__spec">
              <span class="product-main__spec-label">Année</span>
              <span>{{ product.metafields.custom.year }}</span>
            </div>
          {% endif %}
          {% if product.metafields.custom.mileage %}
            <div class="product-main__spec">
              <span class="product-main__spec-label">Kilométrage</span>
              <span>{{ product.metafields.custom.mileage | append: ' km' }}</span>
            </div>
          {% endif %}
          {% if product.metafields.custom.fuel_type %}
            <div class="product-main__spec">
              <span class="product-main__spec-label">Carburant</span>
              <span>{{ product.metafields.custom.fuel_type }}</span>
            </div>
          {% endif %}
          {% if product.metafields.custom.transmission %}
            <div class="product-main__spec">
              <span class="product-main__spec-label">Boîte</span>
              <span>{{ product.metafields.custom.transmission }}</span>
            </div>
          {% endif %}
        </div>

        {% if product.description != blank %}
          <div class="product-main__description">
            {{ product.description }}
          </div>
        {% endif %}

        <div class="product-main__actions">
          <a href="tel:{{ settings.header_phone }}" class="btn btn--primary btn--lg">📞 Nous appeler</a>
          <a href="/pages/contact?vehicle={{ product.title | url_encode }}" class="btn btn--outline btn--lg">✉️ Demande d'information</a>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Produit principal",
  "class": "section-product-main"
}
{% endschema %}
