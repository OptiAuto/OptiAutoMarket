<section class="page-404">
  <div class="container">
    <h1>Page introuvable</h1>
    <p>La page que vous recherchez n'existe plus ou a été déplacée.</p>
    <a href="{{ routes.root_url }}" class="btn btn--primary btn--lg">Retour à l'accueil</a>
  </div>
</section>

<style>
  .page-404 { text-align: center; padding: 120px 0; }
  .page-404 h1 { font-size: 2.5rem; font-weight: 800; color: #0f2255; margin-bottom: 12px; }
  .page-404 p { color: #718096; font-size: 17px; margin-bottom: 32px; }
</style>

{% schema %}
{ "name": "Page 404" }
{% endschema %}
