{% comment %}
  Section: Témoignages clients
{% endcomment %}

<div class="testimonials section">
  <div class="page-width">
    <h2 class="section__title">{{ section.settings.title | default: "Ils nous font confiance" }}</h2>
    <p class="section__subtitle">{{ section.settings.subtitle | default: "Découvrez les retours d'expérience de nos clients" }}</p>

    <div class="testimonials__slider">
      {% for block in section.blocks %}
        {% if block.type == 'testimonial' %}
          <div class="testimonials__card" {{ block.shopify_attributes }}>
            <div class="testimonials__stars">★★★★★</div>
            <p class="testimonials__text">"{{ block.settings.text }}"</p>
            <div class="testimonials__author">
              <strong>{{ block.settings.author }}</strong>
              <span>{{ block.settings.date }}</span>
            </div>
          </div>
        {% endif %}
      {% endfor %}

      {% if section.blocks.size == 0 %}
        <div class="testimonials__card">
          <div class="testimonials__stars">★★★★★</div>
          <p class="testimonials__text">"Site clair, explications précises et réponses immédiates. Achat réglé en moins d'une semaine, sans stress. À recommander."</p>
          <div class="testimonials__author">
            <strong>Delphine R.</strong>
            <span>Janvier 2025</span>
          </div>
        </div>
        <div class="testimonials__card">
          <div class="testimonials__stars">★★★★★</div>
          <p class="testimonials__text">"Tout à fait satisfait de l'achat de mon véhicule. L'équipe a toujours été réactive dans nos échanges et efficace. Je recommande."</p>
          <div class="testimonials__author">
            <strong>Stéphane N.</strong>
            <span>Janvier 2025</span>
          </div>
        </div>
        <div class="testimonials__card">
          <div class="testimonials__stars">★★★★★</div>
          <p class="testimonials__text">"Le site est très bien, aussi bien pour les acheteurs que pour les vendeurs. Professionnalisme et réactivité au rendez-vous."</p>
          <div class="testimonials__author">
            <strong>Bernard A.</strong>
            <span>Janvier 2025</span>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Témoignages",
  "class": "section-testimonials",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Ce qu'ils en pensent"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Ne nous croyez pas sur parole, voyez ce qu'ils ont à dire"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Témoignage",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Témoignage"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Auteur"
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date"
        }
      ]
    }
  ]
}
{% endschema %}
