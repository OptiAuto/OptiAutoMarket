<div class="search page-width">
  <h1>Recherche</h1>
  <form action="{{ routes.search_url }}" method="get">
    <input type="search" name="q" value="{{ search.terms }}" placeholder="Marque, modèle ou référence...">
    <input type="hidden" name="type" value="product">
    <button type="submit">Rechercher</button>
  </form>
  {% if search.performed %}
    <p>{{ search.results_count }} résultat(s)</p>
    <div class="search-results">
      {% for product in search.results %}
        {% render 'vehicle-card', product: product %}
      {% endfor %}
    </div>
  {% endif %}
</div>

<style>
.search { padding: 48px 0; }
.search form { margin-bottom: 32px; display: flex; gap: 12px; }
.search-results { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px; }
</style>

{% schema %}
{
  "name": "Recherche",
  "class": "section-main-search"
}
{% endschema %}
