<section class="hero">
  <div class="hero__bg"></div>
  <div class="hero__overlay"></div>
  <div class="hero__content container">
    <h1 class="hero__title">{{ section.settings.title | default: "Voiture d'occasion : achetez en toute confiance" }}</h1>
    <p class="hero__subtitle">{{ section.settings.subtitle | default: "Véhicules contrôlés sur 200 points, garantis et au meilleur prix. Nous vous accompagnons de A à Z." }}</p>
    <div class="hero__actions">
      <a href="/collections/voitures" class="btn btn--accent btn--lg">Voir les véhicules</a>
      <a href="/pages/vendre" class="btn btn--white btn--lg">Vendre ma voiture</a>
    </div>
    <form action="{{ routes.search_url }}" method="get" class="hero__search">
      <input type="hidden" name="type" value="product">
      <input type="search" name="q" placeholder="Rechercher par marque, modèle..." class="hero__search-input" aria-label="Rechercher">
      <button type="submit" class="btn btn--primary">Rechercher</button>
    </form>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "class": "section-hero",
  "settings": [
    { "type": "text", "id": "title", "label": "Titre", "default": "Voiture d'occasion : achetez en toute confiance" },
    { "type": "textarea", "id": "subtitle", "label": "Sous-titre", "default": "Véhicules contrôlés sur 200 points, garantis et au meilleur prix. Nous vous accompagnons de A à Z." }
  ]
}
{% endschema %}
