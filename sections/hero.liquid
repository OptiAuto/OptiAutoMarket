<section class="hero">
  <div class="hero__content container">
    <h1 class="hero__title">{{ section.settings.title | default: "Trouvez votre véhicule révisé, garanti et au meilleur prix" }}</h1>
    <div class="hero__actions">
      <a href="/collections/voitures-doccasion" class="btn btn--white btn--lg">Voir les véhicules</a>
      <a href="/pages/vendre" class="btn btn--outline-white btn--lg">Vendre ma voiture</a>
    </div>
    <form action="{{ routes.search_url }}" method="get" class="hero__search">
      <input type="hidden" name="type" value="product">
      <svg class="hero__search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      <input type="search" name="q" placeholder="Rechercher par marque, modèle..." class="hero__search-input" aria-label="Rechercher">
      <button type="submit" class="btn btn--accent">Rechercher</button>
    </form>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "class": "section-hero",
  "settings": [
    { "type": "text", "id": "title", "label": "Titre", "default": "Trouvez votre véhicule révisé, garanti et au meilleur prix" }
  ]
}
{% endschema %}
