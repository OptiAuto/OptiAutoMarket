{% assign filter_body_types = "Berline,Break,Cabriolet,Citadine,Compact,Coupé,Crossover,Ludospace,Micro-citadine,Monospace,Monospace compact,Pick-up,Roadster,SUV,SUV compact,SUV coupé,4x4,Utilitaire,Van" | split: "," %}
{% assign filter_fuels = "Essence,Diesel,Hybride,Hybride rechargeable,Électrique,Autre" | split: "," %}
{% assign filter_gearboxes = "Manuelle,Automatique,Semi-automatique,Robotisée" | split: "," %}
