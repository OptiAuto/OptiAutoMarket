<section class="testimonials">
  <div class="container">
    <h2 class="section-title">{{ section.settings.title | default: "Ils nous font confiance" }}</h2>
    <p class="section-subtitle">{{ section.settings.subtitle | default: "Plus de 2 500 clients accompagnés depuis notre création." }}</p>

    <div class="testimonials-grid">
      {% for block in section.blocks %}
        <div class="testimonial" {{ block.shopify_attributes }}>
          <div class="testimonial__stars">★★★★★</div>
          <p class="testimonial__text">{{ block.settings.text }}</p>
          <div class="testimonial__author">
            <span class="testimonial__name">{{ block.settings.name }}</span>
            <span class="testimonial__info">{{ block.settings.info }}</span>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Témoignages",
  "class": "section-testimonials",
  "settings": [
    { "type": "text", "id": "title", "label": "Titre", "default": "Ils nous font confiance" },
    { "type": "text", "id": "subtitle", "label": "Sous-titre", "default": "Plus de 2 500 clients accompagnés depuis notre création." }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Témoignage",
      "settings": [
        { "type": "textarea", "id": "text", "label": "Texte", "default": "Service au top ! La voiture correspondait parfaitement à la description." },
        { "type": "text", "id": "name", "label": "Nom", "default": "Marie D." },
        { "type": "text", "id": "info", "label": "Détails", "default": "Peugeot 3008, avril 2025" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Témoignages",
      "blocks": [
        { "type": "testimonial", "settings": { "text": "Service impeccable du début à la fin. Le véhicule correspondait parfaitement à l'annonce et le processus d'achat a été simple et rapide. Je recommande sans hésiter.", "name": "Marie D.", "info": "Peugeot 3008 – mars 2025" } },
        { "type": "testimonial", "settings": { "text": "J'ai vendu ma voiture en 48h avec un prix juste. L'équipe est professionnelle et réactive. Une expérience bien supérieure à ce que j'avais connu jusqu'ici.", "name": "Julien P.", "info": "Renault Mégane – janvier 2025" } },
        { "type": "testimonial", "settings": { "text": "Excellent rapport qualité-prix et un accompagnement sérieux. La garantie comprise dans le prix m'a vraiment rassuré. Merci à toute l'équipe !", "name": "Sophie L.", "info": "Volkswagen Golf – février 2025" } }
      ]
    }
  ]
}
{% endschema %}
