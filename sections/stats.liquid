<section class="stats">
  <div class="container">
    <div class="stats-grid">
      {% for block in section.blocks %}
        <div class="stat" {{ block.shopify_attributes }}>
          <span class="stat__number">{{ block.settings.value }}</span>
          <span class="stat__label">{{ block.settings.label }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Chiffres clés",
  "class": "section-stats",
  "blocks": [
    {
      "type": "stat",
      "name": "Chiffre",
      "settings": [
        { "type": "text", "id": "value", "label": "Valeur", "default": "2 500+" },
        { "type": "text", "id": "label", "label": "Label", "default": "Véhicules vendus" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Chiffres clés",
      "blocks": [
        { "type": "stat", "settings": { "value": "2 500+", "label": "Véhicules vendus" } },
        { "type": "stat", "settings": { "value": "98 %", "label": "Clients satisfaits" } },
        { "type": "stat", "settings": { "value": "200", "label": "Points de contrôle" } },
        { "type": "stat", "settings": { "value": "24 mois", "label": "Garantie possible" } }
      ]
    }
  ]
}
{% endschema %}
