  Sources : CapCar, La Centrale, AutoHero, Carizy, Spoticar, Le Bon Coin
{% endcomment %}

{% assign filter_brands = "Abarth,Alfa Romeo,Alpine,Audi,BMW,Citroën,Cupra,Dacia,DS,Fiat,Ford,Honda,Hyundai,Jaguar,Jeep,Kia,Land Rover,Lexus,Mazda,Mercedes-Benz,MG,Mini,Mitsubishi,Nissan,Opel,Peugeot,Porsche,Renault,Seat,Skoda,Smart,Suzuki,Tesla,Toyota,Volkswagen,Volvo" | split: "," %}

