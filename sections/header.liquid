{% comment %}
  Section: En-tête OptiAuto Market
{% endcomment %}

<header class="header" role="banner">
  <div class="header__announcement">
    <div class="header__announcement-inner">
      <span>🚗 Plus de 10 000 véhicules d'occasion • Garantie incluse • Livraison possible</span>
      <a href="tel:{{ section.settings.phone | default: settings.header_phone }}">{{ section.settings.phone | default: settings.header_phone }}</a>
    </div>
  </div>

  <div class="header__main">
    <div class="header__container page-width">
      <a href="{{ routes.root_url }}" class="header__logo">
        <span class="header__logo-text">OptiAuto</span>
        <span class="header__logo-sub">Market</span>
      </a>

      <nav class="header__nav" aria-label="Navigation principale">
        <ul class="header__nav-list">
          <li><a href="{{ routes.root_url }}">Accueil</a></li>
          <li><a href="{{ routes.collections_url }}">Voitures d'occasion</a></li>
          <li><a href="/pages/comment-ca-marche">Comment ça marche</a></li>
          <li><a href="/pages/garanties">Nos garanties</a></li>
          <li><a href="/pages/estimation">Estimer ma voiture</a></li>
        </ul>
      </nav>

      <div class="header__actions">
        <a href="tel:{{ section.settings.phone | default: settings.header_phone }}" class="header__phone">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          {{ section.settings.phone | default: settings.header_phone }}
        </a>
        <a href="/pages/vendre-ma-voiture" class="header__cta btn btn--primary">
          {{ section.settings.cta_text | default: settings.header_cta_text }}
        </a>
      </div>

      <button type="button" class="header__menu-toggle" aria-label="Menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "En-tête",
  "type": "header",
  "class": "section-header",
  "settings": [
    {
      "type": "text",
      "id": "phone",
      "label": "Téléphone",
      "default": "01 23 45 67 89"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texte bouton vente",
      "default": "Vendre ma voiture"
    }
  ]
}
{% endschema %}
