<div class="estimation-page">
  <div class="container">
    <header class="estimation-header">
      <h1>Vendre ma voiture</h1>
      <p>Obtenez une estimation gratuite en quelques clics. Renseignez les informations de votre véhicule.</p>
    </header>

    <form class="estimation-form" id="EstimationForm" action="/contact#contact_form" method="post">
      <input type="hidden" name="form_type" value="contact">
      <input type="hidden" name="utf8" value="✓">
      <input type="hidden" name="contact[subject]" value="Demande d'estimation - Vendre ma voiture">
      <input type="hidden" name="contact[body]" id="EstimationBody" value="">

      <div class="estimation-grid">
        <div class="estimation-form__group">
          <label for="est-email">Email</label>
          <input type="email" id="est-email" name="contact[email]" class="estimation-form__input" placeholder="votre@email.com">
        </div>
        <div class="estimation-form__group">
          <label for="est-phone">Téléphone</label>
          <input type="tel" id="est-phone" name="contact[phone]" class="estimation-form__input" placeholder="06 XX XX XX XX">
        </div>
        <div class="estimation-form__group">
          <label for="est-plaque">Plaque <span class="required">*</span></label>
          <input type="text" id="est-plaque" class="estimation-form__input" placeholder="AB-123-CD" required maxlength="20">
        </div>
        <div class="estimation-form__group">
          <label for="est-modele">Modèle <span class="required">*</span></label>
          <input type="text" id="est-modele" class="estimation-form__input" placeholder="ex. Renault Clio" required maxlength="120">
        </div>
        <div class="estimation-form__group">
          <label for="est-carburant">Carburant <span class="required">*</span></label>
          <select id="est-carburant" class="estimation-form__input" required>
            <option value="">— Choisir —</option>
            <option value="Essence">Essence</option>
            <option value="Diesel">Diesel</option>
            <option value="Hybride">Hybride</option>
            <option value="Hybride rechargeable">Hybride rechargeable</option>
            <option value="Électrique">Électrique</option>
            <option value="Autre">Autre</option>
          </select>
        </div>
        <div class="estimation-form__group">
          <label for="est-boite">Boîte de vitesse <span class="required">*</span></label>
          <select id="est-boite" class="estimation-form__input" required>
            <option value="">— Choisir —</option>
            <option value="Manuelle">Manuelle</option>
            <option value="Automatique">Automatique</option>
            <option value="Semi-automatique">Semi-automatique</option>
            <option value="Robotisée">Robotisée</option>
          </select>
        </div>
        <div class="estimation-form__group">
          <label for="est-annee">Année d'immatriculation <span class="required">*</span></label>
          <input type="number" id="est-annee" class="estimation-form__input" placeholder="ex. 2019" min="1990" max="2030" required>
        </div>
        <div class="estimation-form__group">
          <label for="est-km">Kilométrage <span class="required">*</span></label>
          <input type="number" id="est-km" class="estimation-form__input" placeholder="ex. 45000" min="0" step="1000" required>
        </div>
      </div>

      <div class="estimation-form__block">
        <label class="estimation-form__block-label">État mécanique</label>
        <div class="estimation-form__radios">
          <label class="estimation-form__radio"><input type="radio" name="est-mecanique" value="Excellent"> Excellent</label>
          <label class="estimation-form__radio"><input type="radio" name="est-mecanique" value="Bon"> Bon</label>
          <label class="estimation-form__radio"><input type="radio" name="est-mecanique" value="Moyen"> Moyen</label>
          <label class="estimation-form__radio"><input type="radio" name="est-mecanique" value="Mauvais"> Mauvais</label>
        </div>
      </div>

      <div class="estimation-form__block">
        <label class="estimation-form__block-label">État carrosserie</label>
        <div class="estimation-form__radios">
          <label class="estimation-form__radio"><input type="radio" name="est-carrosserie" value="Excellent"> Excellent</label>
          <label class="estimation-form__radio"><input type="radio" name="est-carrosserie" value="Bon"> Bon</label>
          <label class="estimation-form__radio"><input type="radio" name="est-carrosserie" value="Moyen"> Moyen</label>
          <label class="estimation-form__radio"><input type="radio" name="est-carrosserie" value="Mauvais"> Mauvais</label>
        </div>
      </div>

      <div class="estimation-form__submit">
        <button type="submit" class="btn btn--primary btn--lg" id="EstimationSubmitBtn">Envoyer</button>
      </div>

      <div class="estimation-form__success" id="EstimationSuccess" style="display:none;">
        <p><strong>Demande envoyée.</strong> Nous vous recontacterons rapidement pour votre estimation.</p>
      </div>
    </form>
  </div>
</div>
