<div class="product-page">
  <div class="container">

    <nav class="breadcrumb">
      <a href="{{ routes.root_url }}">Accueil</a>
      <span>/</span>
      <a href="/collections/voitures-doccasion">Voitures d'occasion</a>
      <span>/</span>
      <span>{{ product.vendor }} {{ product.metafields.custom.model | default: product.title }}</span>
    </nav>

    <div class="product-grid">

      <div class="product-gallery">
        <div class="product-gallery__main" id="GalleryMain">
          {% if product.images.size > 0 %}
            <img src="{{ product.featured_image | image_url: width: 900 }}" alt="{{ product.title | escape }}" id="MainImg">
          {% else %}
            <div class="product-gallery__placeholder">
              <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
            </div>
          {% endif %}
          {% if product.images.size > 1 %}
            <button class="gallery-arrow gallery-arrow--prev" id="GalleryPrev" aria-label="Photo précédente">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m15 18-6-6 6-6"/></svg>
            </button>
            <button class="gallery-arrow gallery-arrow--next" id="GalleryNext" aria-label="Photo suivante">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
            </button>
            <div class="gallery-counter" id="GalleryCounter">1 / {{ product.images.size }}</div>
          {% endif %}
        </div>
        {% if product.images.size > 1 %}
          <div class="product-gallery__thumbs" id="GalleryThumbs">
            {% for image in product.images %}
              <button class="product-gallery__thumb {% if forloop.first %}is-active{% endif %}" data-index="{{ forloop.index0 }}" data-src="{{ image | image_url: width: 900 }}">
                <img src="{{ image | image_url: width: 120, height: 90, crop: 'center' }}" alt="Photo {{ forloop.index }}" loading="lazy" width="120" height="90">
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="product-info">
        {% if product.metafields.custom.badge != blank %}
          <span class="product-info__badge">{{ product.metafields.custom.badge }}</span>
        {% endif %}

        <div class="product-info__price">{{ product.price | money_without_trailing_zeros }}</div>

        <h1 class="product-info__title">{{ product.vendor }} {{ product.metafields.custom.model | default: product.title }}</h1>

        {% if product.metafields.custom.trim != blank %}
          <p class="product-info__trim">{{ product.metafields.custom.trim }}</p>
        {% endif %}

        {% if product.metafields.custom.engine != blank %}
          <p class="product-info__engine">{{ product.metafields.custom.engine }}</p>
        {% endif %}

        <div class="product-info__badges">
          <span class="trust-badge">Véhicule contrôlé</span>
          <span class="trust-badge">Garantie incluse</span>
          <span class="trust-badge">Paiement sécurisé</span>
        </div>

        <div class="product-info__keyinfo">
          <h2>Informations clés</h2>
          <div class="keyinfo-grid">
            {% if product.metafields.custom.model != blank %}
              <div class="keyinfo-item"><span class="keyinfo-label">Modèle</span><span class="keyinfo-value">{{ product.metafields.custom.model }}</span></div>
            {% endif %}
            {% if product.metafields.custom.year != blank %}
              <div class="keyinfo-item"><span class="keyinfo-label">Mise en circulation</span><span class="keyinfo-value">{{ product.metafields.custom.year }}</span></div>
            {% endif %}
            {% if product.metafields.custom.mileage != blank %}
              <div class="keyinfo-item"><span class="keyinfo-label">Kilométrage</span><span class="keyinfo-value">{{ product.metafields.custom.mileage }} km</span></div>
            {% endif %}
            {% if product.metafields.custom.fuel != blank %}
              <div class="keyinfo-item"><span class="keyinfo-label">Carburant</span><span class="keyinfo-value">{{ product.metafields.custom.fuel }}</span></div>
            {% endif %}
            {% if product.metafields.custom.gearbox != blank %}
              <div class="keyinfo-item"><span class="keyinfo-label">Boîte de vitesses</span><span class="keyinfo-value">{{ product.metafields.custom.gearbox }}</span></div>
            {% endif %}
            {% if product.metafields.custom.transmission != blank %}
              <div class="keyinfo-item"><span class="keyinfo-label">Transmission</span><span class="keyinfo-value">{{ product.metafields.custom.transmission }}</span></div>
            {% endif %}
            {% if product.metafields.custom.power != blank %}
              <div class="keyinfo-item"><span class="keyinfo-label">Puissance</span><span class="keyinfo-value">{{ product.metafields.custom.power }}</span></div>
            {% endif %}
            {% if product.metafields.custom.critair != blank %}
              <div class="keyinfo-item"><span class="keyinfo-label">Crit'Air</span><span class="keyinfo-value">{{ product.metafields.custom.critair }}</span></div>
            {% endif %}
            {% if product.metafields.custom.color != blank %}
              <div class="keyinfo-item"><span class="keyinfo-label">Couleur</span><span class="keyinfo-value">{{ product.metafields.custom.color }}</span></div>
            {% endif %}
            {% if product.metafields.custom.doors != blank %}
              <div class="keyinfo-item"><span class="keyinfo-label">Portes</span><span class="keyinfo-value">{{ product.metafields.custom.doors }}</span></div>
            {% endif %}
            {% if product.metafields.custom.seats != blank %}
              <div class="keyinfo-item"><span class="keyinfo-label">Places</span><span class="keyinfo-value">{{ product.metafields.custom.seats }}</span></div>
            {% endif %}
            {% if product.metafields.custom.co2 != blank %}
              <div class="keyinfo-item"><span class="keyinfo-label">Émissions CO₂</span><span class="keyinfo-value">{{ product.metafields.custom.co2 }} g/km</span></div>
            {% endif %}
          </div>
        </div>

        {% if product.metafields.custom.options != blank %}
          <div class="product-info__options">
            <h2>Équipements et options</h2>
            <ul class="options-list">
              {% assign options_list = product.metafields.custom.options | split: ',' %}
              {% for opt in options_list %}
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg>
                  {{ opt | strip }}
                </li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}

        {% if product.description != blank %}
          <div class="product-info__desc">
            <h2>Description</h2>
            {{ product.description }}
          </div>
        {% endif %}

        <div class="product-info__guarantee">
          <h2>Garantie</h2>
          <div class="guarantee-card">
            <div class="guarantee-card__item guarantee-card__item--included">
              <strong>Garantie 6 mois incluse</strong>
              <p>Moteur, boîte de vitesses, direction, suspension, freinage, climatisation, électricité.</p>
            </div>
            <div class="guarantee-card__item">
              <strong>Extension 12 mois</strong>
              <p>Prolongez votre tranquillité d'esprit avec une couverture étendue.</p>
            </div>
          </div>
        </div>

        <div class="product-info__contact">
          <h2>Intéressé par ce véhicule ?</h2>
          <p>Réservez une visite ou un essai routier. Notre équipe est disponible pour répondre à vos questions.</p>
          <div class="product-info__contact-actions">
            <a href="tel:{{ settings.phone }}" class="btn btn--primary btn--lg">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.81.36 1.6.7 2.34a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.74.34 1.53.57 2.34.7A2 2 0 0 1 22 16.92z"/></svg>
              Appeler : {{ settings.phone }}
            </a>
            <button type="button" class="btn btn--ghost btn--lg" id="OpenContactModal">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              Envoyer un message
            </button>
          </div>
        </div>

        <div class="contact-overlay" id="ContactOverlay">
          <div class="contact-modal">
            <button type="button" class="contact-modal__close" id="CloseContactModal">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            </button>
            <h3>Envoyer un message</h3>
            <p>Concernant : {{ product.vendor }} {{ product.metafields.custom.model | default: product.title }}</p>
            <form id="ContactForm" action="/contact#contact_form" method="post">
              <input type="hidden" name="form_type" value="contact">
              <input type="hidden" name="utf8" value="✓">
              <input type="hidden" name="contact[subject]" value="Demande pour {{ product.vendor }} {{ product.metafields.custom.model | default: product.title }}">
              <div class="contact-form__group">
                <label>Email</label>
                <input type="email" name="contact[email]" class="contact-form__input" placeholder="votre@email.com">
              </div>
              <div class="contact-form__group">
                <label>Téléphone <span class="required">*</span></label>
                <input type="tel" name="contact[phone]" class="contact-form__input" placeholder="06 XX XX XX XX" required>
                <div class="contact-form__error" id="phoneError">Veuillez renseigner votre numéro de téléphone</div>
              </div>
              <div class="contact-form__group">
                <label>Message <span class="required">*</span></label>
                <textarea name="contact[body]" class="contact-form__input" placeholder="Bonjour, je suis intéressé(e) par ce véhicule..." required></textarea>
                <div class="contact-form__error" id="messageError">Veuillez rédiger votre message</div>
              </div>
              <button type="submit" class="btn btn--primary btn--lg" style="width:100%" id="ContactSubmitBtn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2 11 13"/><polygon points="22 2 15 22 11 13 2 9"/></svg>
                Envoyer
              </button>
            </form>
            <div class="contact-form__success" id="ContactSuccess" style="display:none;">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <h4>Message envoyé !</h4>
              <p>Nous vous répondrons dans les plus brefs délais.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
(function() {
  var images = [];
  {% for image in product.images %}
    images.push("{{ image | image_url: width: 900 }}");
  {% endfor %}

  if (images.length <= 1) return;

  var current = 0;
  var mainImg = document.getElementById('MainImg');
  var counter = document.getElementById('GalleryCounter');
  var thumbs = document.querySelectorAll('.product-gallery__thumb');
  var prevBtn = document.getElementById('GalleryPrev');
  var nextBtn = document.getElementById('GalleryNext');

  function goTo(idx) {
    current = (idx + images.length) % images.length;
    var newImg = new Image();
    newImg.src = images[current];
    newImg.onload = function() {
      mainImg.style.opacity = '0';
      setTimeout(function() {
        mainImg.src = images[current];
        mainImg.style.opacity = '1';
      }, 200);
    };
    if (counter) counter.textContent = (current + 1) + ' / ' + images.length;
    thumbs.forEach(function(t, i) {
      t.classList.toggle('is-active', i === current);
    });
    var activeThumb = thumbs[current];
    if (activeThumb) activeThumb.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
  }

  if (prevBtn) prevBtn.addEventListener('click', function() { goTo(current - 1); });
  if (nextBtn) nextBtn.addEventListener('click', function() { goTo(current + 1); });

  thumbs.forEach(function(thumb) {
    thumb.addEventListener('click', function() {
      goTo(parseInt(this.dataset.index, 10));
    });
  });

  var startX = 0;
  var gallery = document.getElementById('GalleryMain');
  gallery.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; }, { passive: true });
  gallery.addEventListener('touchend', function(e) {
    var diff = startX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) goTo(diff > 0 ? current + 1 : current - 1);
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'ArrowLeft') goTo(current - 1);
    if (e.key === 'ArrowRight') goTo(current + 1);
  });
})();

(function() {
  var overlay = document.getElementById('ContactOverlay');
  var openBtn = document.getElementById('OpenContactModal');
  var closeBtn = document.getElementById('CloseContactModal');
  var form = document.getElementById('ContactForm');
  var success = document.getElementById('ContactSuccess');

  if (!overlay || !openBtn) return;

  function open() { overlay.classList.add('is-open'); document.body.style.overflow = 'hidden'; }
  function close() { overlay.classList.remove('is-open'); document.body.style.overflow = ''; }

  openBtn.addEventListener('click', open);
  closeBtn.addEventListener('click', close);
  overlay.addEventListener('click', function(e) { if (e.target === overlay) close(); });
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape' && overlay.classList.contains('is-open')) close(); });

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var phone = form.querySelector('[name="contact[phone]"]');
    var msg = form.querySelector('[name="contact[body]"]');
    var phoneErr = document.getElementById('phoneError');
    var msgErr = document.getElementById('messageError');
    var valid = true;

    phoneErr.style.display = 'none';
    msgErr.style.display = 'none';
    phone.classList.remove('contact-form__input--error');
    msg.classList.remove('contact-form__input--error');

    if (!phone.value.trim()) {
      phoneErr.style.display = 'block';
      phone.classList.add('contact-form__input--error');
      valid = false;
    }
    if (!msg.value.trim()) {
      msgErr.style.display = 'block';
      msg.classList.add('contact-form__input--error');
      valid = false;
    }
    if (!valid) return;

    var btn = document.getElementById('ContactSubmitBtn');
    btn.disabled = true;
    btn.textContent = 'Envoi en cours...';

    var formData = new FormData(form);
    fetch('/contact#contact_form', {
      method: 'POST',
      body: formData,
      headers: { 'Accept': 'text/html' }
    }).then(function() {
      form.style.display = 'none';
      success.style.display = 'block';
      setTimeout(close, 3000);
    }).catch(function() {
      btn.disabled = false;
      btn.textContent = 'Envoyer';
      alert('Une erreur est survenue. Veuillez réessayer.');
    });
  });
})();
</script>
