{% comment %}
  Section: Avantages (Contrôle, Garantie, Qualité/Prix)
{% endcomment %}

<div class="features section section--alt">
  <div class="page-width">
    <h2 class="section__title">{{ section.settings.title | default: "Bienvenue chez OptiAuto" }}</h2>
    <p class="section__subtitle">{{ section.settings.subtitle | default: "Achetez une voiture d'occasion sans stress. On vous accompagne de A à Z !" }}</p>

    <div class="features__grid">
      <div class="features__card">
        <span class="features__icon">👨‍🔧</span>
        <h3>Voitures contrôlées</h3>
        <p>Les véhicules sont contrôlés sur 200 points de contrôle, et leur bon état mécanique est vérifié de manière transparente.</p>
        {% if section.settings.link1 != blank %}
          <a href="{{ section.settings.link1 }}" class="features__link">En savoir plus →</a>
        {% endif %}
      </div>
      <div class="features__card">
        <span class="features__icon">🚗</span>
        <h3>Meilleur qualité / prix</h3>
        <p>Familiale, sportive, électrique, utilitaire... Trouvez votre bonheur en quelques clics.</p>
        {% if section.settings.link2 != blank %}
          <a href="{{ section.settings.link2 }}" class="features__link">En savoir plus →</a>
        {% endif %}
      </div>
      <div class="features__card">
        <span class="features__icon">👍</span>
        <h3>Garantie incluse</h3>
        <p>C'est presque comme du neuf, sans le prix du neuf, avec une garantie de 6 mois minimum.</p>
        {% if section.settings.link3 != blank %}
          <a href="{{ section.settings.link3 }}" class="features__link">En savoir plus →</a>
        {% endif %}
      </div>
    </div>

    {% if section.settings.cta_text != blank %}
      <div class="features__cta">
        <p>{{ section.settings.cta_text }}</p>
        <a href="/pages/vendre-ma-voiture" class="btn btn--primary">{{ section.settings.cta_button | default: "Je vends ma voiture" }}</a>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Avantages",
  "class": "section-features",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Bienvenue chez OptiAuto"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Achetez une voiture d'occasion sans stress. On vous accompagne de A à Z !"
    },
    {
      "type": "url",
      "id": "link1",
      "label": "Lien carte 1"
    },
    {
      "type": "url",
      "id": "link2",
      "label": "Lien carte 2"
    },
    {
      "type": "url",
      "id": "link3",
      "label": "Lien carte 3"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texte CTA vente",
      "default": "Vous souhaitez vendre votre voiture ? Pas de problème on est là !"
    },
    {
      "type": "text",
      "id": "cta_button",
      "label": "Texte bouton CTA",
      "default": "Je vends ma voiture"
    }
  ]
}
{% endschema %}
