{% comment %}
  Carte véhicule - Style CapCar / La Centrale
  Affiche : photo, nom, motorisation, finition, année, km, carburant, boîte, prix
{% endcomment %}

<a href="{{ product.url }}" class="vcard" data-brand="{{ product.vendor | handleize }}" data-fuel="{{ product.metafields.custom.fuel | handleize }}" data-gearbox="{{ product.metafields.custom.gearbox | handleize }}" data-body="{{ product.metafields.custom.body_type | handleize }}" data-year="{{ product.metafields.custom.year }}" data-km="{{ product.metafields.custom.mileage }}" data-seats="{{ product.metafields.custom.seats }}" data-critair="{{ product.metafields.custom.critair | handleize }}" data-color="{{ product.metafields.custom.color | handleize }}" data-transmission="{{ product.metafields.custom.transmission | handleize }}" data-price="{{ product.price }}">

  <div class="vcard__img">
    {% if product.featured_image != blank %}
      <img src="{{ product.featured_image | image_url: width: 480, height: 320, crop: 'center' }}" alt="{{ product.title | escape }}" loading="lazy" width="480" height="320">
    {% else %}
      <div class="vcard__img-placeholder">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
      </div>
    {% endif %}
    {% if product.metafields.custom.badge != blank %}
      <span class="vcard__badge">{{ product.metafields.custom.badge }}</span>
    {% endif %}
  </div>

  <div class="vcard__body">
    <div class="vcard__price">{{ product.price | money_without_trailing_zeros }}</div>

    <h3 class="vcard__title">{{ product.vendor }} {{ product.metafields.custom.model | default: product.title }}</h3>

    {% if product.metafields.custom.trim != blank %}
      <p class="vcard__trim">{{ product.metafields.custom.trim }}</p>
    {% endif %}

    {% if product.metafields.custom.engine != blank %}
      <p class="vcard__engine">{{ product.metafields.custom.engine }}</p>
    {% endif %}

    <div class="vcard__specs">
      {% if product.metafields.custom.year != blank %}
        <span class="vcard__spec">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
          {{ product.metafields.custom.year }}
        </span>
      {% endif %}
      {% if product.metafields.custom.mileage != blank %}
        <span class="vcard__spec">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 12m-10 0a10 10 0 1 0 20 0a10 10 0 1 0-20 0"/><path d="M12 12l4-4"/></svg>
          {{ product.metafields.custom.mileage | append: ' km' }}
        </span>
      {% endif %}
      {% if product.metafields.custom.fuel != blank %}
        <span class="vcard__spec">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 22V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v17"/><path d="M15 11h2a2 2 0 0 1 2 2v2a2 2 0 0 0 2 2h0a2 2 0 0 0 2-2V9.83a2 2 0 0 0-.59-1.42L18 4"/></svg>
          {{ product.metafields.custom.fuel }}
        </span>
      {% endif %}
      {% if product.metafields.custom.gearbox != blank %}
        <span class="vcard__spec">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="5" cy="6" r="2"/><circle cx="12" cy="6" r="2"/><circle cx="19" cy="6" r="2"/><circle cx="5" cy="18" r="2"/><circle cx="19" cy="18" r="2"/><path d="M5 8v8M19 8v8M12 8v4h7"/></svg>
          {{ product.metafields.custom.gearbox }}
        </span>
      {% endif %}
    </div>
  </div>
</a>
