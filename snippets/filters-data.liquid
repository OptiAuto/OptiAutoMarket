{% assign filter_fuels = "Essence,Diesel,Électrique,Hybride essence,Hybride diesel,Essence / GPL,E85 (Flexfuel)" | split: "," %}

{% assign filter_gearboxes = "Manuelle,Automatique,Semi-automatique" | split: "," %}

{% assign filter_transmissions = "Traction avant,Propulsion arrière,4 roues motrices (AWD)" | split: "," %}

{% assign filter_seats = "2,4,5,6,7,8,9" | split: "," %}

{% assign filter_critairs = "Crit'Air 0 (Électrique),Crit'Air 1,Crit'Air 2,Crit'Air 3,Crit'Air 4,Crit'Air 5" | split: "," %}

{% assign filter_colors = "Noir,Blanc,Gris,Argent,Bleu,Rouge,Vert,Marron,Beige,Orange,Jaune,Violet" | split: "," %}

