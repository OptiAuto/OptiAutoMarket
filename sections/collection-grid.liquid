<div class="collection-grid section">
  <div class="page-width">
    <div class="collection-grid__toolbar">
      <p class="collection-grid__count">{{ collection.products_count }} véhicule{{ collection.products_count | pluralize: 's', 's' }}</p>
      <div class="collection-grid__sort">
        <label for="SortBy">Trier par</label>
        <select id="SortBy" class="collection-grid__sort-select" onchange="window.location.href=this.value">
          <option value="{{ collection.url }}?sort_by=manual">En vedette</option>
          <option value="{{ collection.url }}?sort_by=best-selling">Meilleures ventes</option>
          <option value="{{ collection.url }}?sort_by=price-ascending">Prix croissant</option>
          <option value="{{ collection.url }}?sort_by=price-descending">Prix décroissant</option>
          <option value="{{ collection.url }}?sort_by=created-descending">Plus récents</option>
        </select>
      </div>
    </div>

    <div class="collection-grid__list">
      {% paginate collection.products by 12 %}
        {% for product in collection.products %}
          {% render 'vehicle-card', product: product %}
        {% else %}
          <p class="collection-grid__empty">Aucun véhicule ne correspond à vos critères.</p>
        {% endfor %}

        {% if paginate.pages > 1 %}
          <div class="collection-grid__pagination">
            {{ paginate | default_pagination }}
          </div>
        {% endif %}
      {% endpaginate %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Grille collection",
  "class": "section-collection-grid"
}
{% endschema %}
