<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="{{ routes.root_url }}" class="footer-logo">
          <img src="{{ 'logo.png' | asset_url }}" alt="OptiAuto" width="140" height="50" style="filter: brightness(0) invert(1);">
        </a>
        <p>Vente, achat et reprise de véhicules d'occasion. Inspection rigoureuse, garantie incluse, accompagnement personnalisé.</p>
      </div>

      <div class="footer-col">
        <h4>Acheter</h4>
        <ul>
          <li><a href="/collections/voitures-doccasion">Tous les véhicules</a></li>
          <li><a href="/collections/voitures-doccasion?body=Citadine">Citadines</a></li>
          <li><a href="/collections/voitures-doccasion?body=SUV">SUV et 4x4</a></li>
          <li><a href="/collections/voitures-doccasion?body=Berline">Berlines</a></li>
          <li><a href="/collections/voitures-doccasion?body=Utilitaire">Utilitaires</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Services</h4>
        <ul>
          <li><a href="/pages/vendre">Vendre ma voiture</a></li>
          <li><a href="/pages/estimation">Estimation gratuite</a></li>
          <li><a href="/pages/reprise">Reprise véhicule</a></li>
          <li><a href="/pages/financement">Financement</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Informations</h4>
        <ul>
          <li><a href="/pages/comment-ca-marche">Comment ça marche</a></li>
          <li><a href="/pages/garanties">Nos garanties</a></li>
          <li><a href="/pages/a-propos">À propos</a></li>
          <li><a href="/pages/contact">Contact</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Contact</h4>
        <ul>
          <li><a href="tel:{{ settings.phone }}">{{ settings.phone }}</a></li>
          <li><a href="mailto:{{ settings.email }}">{{ settings.email }}</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ settings.footer_copyright }}</p>
      <div class="footer-bottom__links">
        <a href="/pages/mentions-legales">Mentions légales</a>
        <a href="/pages/cgv">CGV</a>
        <a href="/pages/confidentialite">Confidentialité</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{ "name": "Pied de page", "class": "section-footer" }
{% endschema %}
