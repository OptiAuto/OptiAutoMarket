<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="{{ routes.root_url }}" class="footer-logo"><strong>OptiAuto</strong><span>Market</span></a>
        <p>Achetez ou vendez votre véhicule d'occasion en toute sérénité. Inspection rigoureuse, garantie incluse, accompagnement de A à Z.</p>
      </div>

      <div class="footer-col">
        <h4>Acheter</h4>
        <ul>
          <li><a href="/collections/voitures">Catalogue complet</a></li>
          <li><a href="/collections/voitures?body=Citadine">Citadines</a></li>
          <li><a href="/collections/voitures?body=SUV">SUV et 4x4</a></li>
          <li><a href="/collections/voitures?body=Berline">Berlines</a></li>
          <li><a href="/collections/voitures?body=Utilitaire">Utilitaires</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Vendre</h4>
        <ul>
          <li><a href="/pages/vendre">Vendre ma voiture</a></li>
          <li><a href="/pages/estimation">Estimation gratuite</a></li>
          <li><a href="/pages/reprise">Reprise véhicule</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Informations</h4>
        <ul>
          <li><a href="/pages/comment-ca-marche">Comment ça marche</a></li>
          <li><a href="/pages/garanties">Nos garanties</a></li>
          <li><a href="/pages/financement">Financement</a></li>
          <li><a href="/pages/contact">Contact</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Contact</h4>
        <ul>
          <li><a href="tel:{{ settings.phone }}">{{ settings.phone }}</a></li>
          <li><a href="mailto:{{ settings.email }}">{{ settings.email }}</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ settings.footer_copyright }}</p>
      <div class="footer-bottom__links">
        <a href="/pages/mentions-legales">Mentions légales</a>
        <a href="/pages/cgv">CGV</a>
        <a href="/pages/confidentialite">Confidentialité</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{ "name": "Pied de page", "class": "section-footer" }
{% endschema %}
