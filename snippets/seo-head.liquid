{% comment %}
  SEO: meta, canonical, Open Graph, Twitter Card, JSON-LD Organization + WebSite
{% endcomment %}
{% assign seo_title = page_title | default: shop.name %}
{% if current_page != 1 %}
  {% assign seo_title = seo_title | append: ' – Page ' | append: current_page %}
{% endif %}
{% assign seo_title = seo_title | append: ' | ' | append: shop.name %}
{% assign seo_desc = page_description | default: settings.seo_default_description | default: 'Vente de véhicules d''occasion contrôlés et garantis. Achat, reprise et estimation gratuite. OptiAuto – votre prochain véhicule au meilleur prix.' %}
{% assign canonical_url_value = canonical_url | default: shop.secure_url | append: request.path %}
{% assign og_image = page_image %}
{% if template.name == 'product' and product.featured_image %}
  {% assign og_image = product.featured_image %}
{% endif %}
{% if og_image == blank or og_image == 'logo.png' %}
  {% assign og_image_url = 'logo.png' | asset_url %}
{% else %}
  {% assign og_image_url = og_image | image_url: width: 1200, height: 630, crop: 'center' %}
{% endif %}

<title>{{ seo_title }}</title>
<meta name="description" content="{{ seo_desc | escape | strip_newlines | truncate: 160 }}">
<link rel="canonical" href="{{ canonical_url_value }}">
{% if template.name == 'search' and search.performed %}<meta name="robots" content="noindex, follow">{% endif %}

<meta property="og:type" content="{% if template.name == 'product' %}product{% elsif template.name == 'article' %}article{% else %}website{% endif %}">
<meta property="og:title" content="{{ seo_title | escape }}">
<meta property="og:description" content="{{ seo_desc | escape | strip_newlines | truncate: 200 }}">
<meta property="og:url" content="{{ canonical_url_value }}">
<meta property="og:site_name" content="{{ shop.name | escape }}">
<meta property="og:image" content="{{ og_image_url | prepend: 'https:' }}">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:locale" content="fr_FR">

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ seo_title | escape }}">
<meta name="twitter:description" content="{{ seo_desc | escape | strip_newlines | truncate: 200 }}">
<meta name="twitter:image" content="{{ og_image_url | prepend: 'https:' }}">

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "{{ shop.secure_url }}/#organization",
      "name": "{{ shop.name | escape }}",
      "url": "{{ shop.secure_url }}",
      "telephone": "{{ settings.phone | escape }}",
      "email": "{{ settings.email | escape }}"
    },
    {
      "@type": "WebSite",
      "@id": "{{ shop.secure_url }}/#website",
      "url": "{{ shop.secure_url }}",
      "name": "{{ shop.name | escape }}",
      "description": "{{ seo_desc | escape | strip_newlines | truncate: 200 }}",
      "publisher": { "@id": "{{ shop.secure_url }}/#organization" },
      "potentialAction": {
        "@type": "SearchAction",
        "target": "{{ shop.secure_url }}/search?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }
    {% if template.name == 'product' and product %}
    ,{
      "@type": "Product",
      "@id": "{{ shop.secure_url }}{{ product.url }}#product",
      "name": "{{ product.vendor }} {{ product.metafields.custom.model | default: product.title | escape }}",
      "description": "{{ product.description | strip_html | escape | truncate: 500 }}",
      "url": "{{ shop.secure_url }}{{ product.url }}",
      "image": {% if product.featured_image %}"{{ product.featured_image | image_url: width: 1200 | prepend: 'https:' }}"{% else %}[]{% endif %},
      "offers": {
        "@type": "Offer",
        "url": "{{ shop.secure_url }}{{ product.url }}",
        "priceCurrency": "{{ cart.currency.iso_code }}",
        "price": "{{ product.price | divided_by: 100.0 }}",
        "availability": "https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}"
      }
      {% if product.metafields.custom.year or product.metafields.custom.mileage %}
      ,"additionalProperty": [
        {% if product.metafields.custom.year %}{"@type":"PropertyValue","name":"Année","value":"{{ product.metafields.custom.year }}"}{% endif %}
        {% if product.metafields.custom.year and product.metafields.custom.mileage %},{% endif %}
        {% if product.metafields.custom.mileage %}{"@type":"PropertyValue","name":"Kilométrage","value":"{{ product.metafields.custom.mileage }} km"}{% endif %}
      ]
      {% endif %}
    }
    {% endif %}
    {% if template.name == 'collection' and collection %}
    ,{
      "@type": "CollectionPage",
      "@id": "{{ shop.secure_url }}{{ collection.url }}#collection",
      "url": "{{ shop.secure_url }}{{ collection.url }}",
      "name": "{{ collection.title | escape }}",
      "description": "{{ collection.description | default: seo_desc | strip_html | escape | truncate: 200 }}",
      "numberOfItems": {{ collection.products_count }}
    }
    ,{
      "@type": "ItemList",
      "itemListElement": [
        {% for product in collection.products limit: 20 %}
        {
          "@type": "ListItem",
          "position": {{ forloop.index }},
          "url": "{{ shop.secure_url }}{{ product.url }}",
          "name": "{{ product.vendor }} {{ product.metafields.custom.model | default: product.title | escape }}"
        }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ]
    }
    {% endif %}
    {% if template.name == 'product' and product %}
    ,{
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "{{ shop.secure_url }}" },
        { "@type": "ListItem", "position": 2, "name": "Voitures", "item": "{{ shop.secure_url }}/collections/voitures" },
        { "@type": "ListItem", "position": 3, "name": "{{ product.vendor }} {{ product.metafields.custom.model | default: product.title | escape }}", "item": "{{ shop.secure_url }}{{ product.url }}" }
      ]
    }
    {% endif %}
  ]
}
</script>
