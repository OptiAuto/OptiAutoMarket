<div class="page-content page-width">
  <h1 class="page-content__title">{{ page.title }}</h1>
  <div class="page-content__body">
    {{ page.content }}
  </div>
</div>

<style>
.page-content { padding: 48px 0 64px; }
.page-content__title { font-family: var(--font-display); margin-bottom: 24px; }
.page-content__body { line-height: 1.8; }
.page-content__body h2 { margin: 32px 0 16px; }
.page-content__body p { margin-bottom: 16px; }
.page-content__body ul { margin: 16px 0; padding-left: 24px; }
.page-content__body li { margin-bottom: 8px; }
</style>

{% schema %}
{
  "name": "Page",
  "class": "section-main-page"
}
{% endschema %}
