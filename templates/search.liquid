<div class="search-page">
  <div class="container">
    <h1>Résultats de recherche</h1>
    <form action="{{ routes.search_url }}" method="get" class="search-form">
      <input type="hidden" name="type" value="product">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Marque, modèle ou référence..." class="search-form__input">
      <button type="submit" class="btn btn--primary">Rechercher</button>
    </form>

    {% if search.performed %}
      {% if search.results_count > 0 %}
        <p class="search-count">{{ search.results_count }} résultat{% if search.results_count > 1 %}s{% endif %} pour « {{ search.terms }} »</p>
        <div class="vgrid">
          {% for item in search.results %}
            {% if item.object_type == 'product' %}
              {% render 'vehicle-card', product: item %}
            {% endif %}
          {% endfor %}
        </div>
      {% else %}
        <p class="search-empty">Aucun résultat pour « {{ search.terms }} ».</p>
        <a href="/collections/voitures-doccasion" class="btn btn--ghost">Voir tous les véhicules</a>
      {% endif %}
    {% endif %}
  </div>
</div>

<style>
  .search-page { padding: 48px 0 80px; }
  .search-page h1 { font-size: 2rem; font-weight: 800; color: #0f2255; margin-bottom: 24px; }
  .search-form { display: flex; gap: 12px; margin-bottom: 32px; max-width: 600px; }
  .search-form__input { flex: 1; padding: 12px 16px; border: 1px solid #cbd5e0; border-radius: 10px; font-size: 15px; }
  .search-form__input:focus { outline: none; border-color: #3068c8; box-shadow: 0 0 0 3px rgba(48,104,200,.12); }
  .search-count { color: #718096; margin-bottom: 24px; }
  .search-empty { color: #718096; margin-bottom: 24px; font-size: 16px; }
</style>
