<header class="site-header">
  <div class="header-main">
    <div class="container header-main__inner">
      <a href="{{ routes.root_url }}" class="header-logo">
        <img src="{{ 'logo.png' | asset_url }}" alt="OptiAuto" class="header-logo__img" width="220" height="72">
      </a>

      <nav class="header-nav" id="MainNav" aria-label="Navigation principale">
        <a href="/collections/voitures-doccasion" class="header-nav__link {% if request.path contains 'voitures' or request.path == '/' %}is-active{% endif %}">Recherche</a>
        <a href="/pages/vendre" class="header-nav__link {% if request.path contains 'vendre' %}is-active{% endif %}">Vendre</a>
        <a href="/pages/garanties" class="header-nav__link {% if request.path contains 'garanties' %}is-active{% endif %}">Garanties</a>
        <a href="/pages/contact" class="header-nav__link {% if request.path contains 'contact' %}is-active{% endif %}">Contact</a>
      </nav>

      <div class="header-actions">
        <a href="tel:{{ settings.phone }}" class="header-actions__phone">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.81.36 1.6.7 2.34a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.74.34 1.53.57 2.34.7A2 2 0 0 1 22 16.92z"/></svg>
          {{ settings.phone }}
        </a>
        <a href="/pages/vendre" class="btn btn--accent btn--sm">Vendre ma voiture</a>
      </div>

      <button class="header-burger" id="MenuToggle" aria-label="Menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <div class="header-search-ribbon">
    <div class="container">
      <p class="header-search-ribbon__title">Votre prochain véhicule, révisé, garanti et au meilleur prix</p>
      <form action="{{ routes.search_url }}" method="get" class="header-search-ribbon__form">
        <input type="hidden" name="type" value="product">
        <svg class="header-search-ribbon__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input type="search" name="q" placeholder="Rechercher par marque, modèle..." class="header-search-ribbon__input" aria-label="Rechercher">
        <button type="submit" class="header-search-ribbon__btn" aria-label="Rechercher">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </button>
      </form>
    </div>
  </div>

  <div class="header-mobile" id="MobileMenu" aria-hidden="true">
    <nav class="header-mobile__nav">
      <a href="/collections/voitures-doccasion">Recherche</a>
      <a href="/pages/vendre">Vendre ma voiture</a>
      <a href="/pages/garanties">Nos garanties</a>
      <a href="/pages/contact">Contact</a>
      <a href="tel:{{ settings.phone }}" class="header-mobile__phone">{{ settings.phone }}</a>
    </nav>
  </div>
</header>

{% schema %}
{ "name": "En-tête", "class": "section-header" }
{% endschema %}
