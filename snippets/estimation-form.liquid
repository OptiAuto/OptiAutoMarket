{% if settings.formspree_estimation_id != blank %}
  {% assign form_action = 'https://formspree.io/f/' | append: settings.formspree_estimation_id %}
  {% assign form_enctype = 'multipart/form-data' %}
{% else %}
  {% assign form_action = '/contact#contact_form' %}
  {% assign form_enctype = '' %}
{% endif %}

<div class="estimation-page">
  <div class="container">
    <header class="estimation-header">
      <p class="estimation-header__intro">Complétez les champs ci-dessous pour une estimation, vente ou une reprise.</p>
    </header>

    <form class="estimation-form" id="EstimationForm" action="{{ form_action }}" method="post" {% if form_enctype != '' %}enctype="multipart/form-data"{% endif %}>
      <input type="hidden" name="form_type" value="contact">
      <input type="hidden" name="utf8" value="✓">
      {% if form_enctype == '' %}
        <input type="hidden" name="contact[subject]" value="Demande estimation / reprise - OptiAuto">
        <input type="hidden" name="contact[body]" id="EstimationBody" value="">
      {% else %}
        <input type="hidden" name="_subject" value="Demande estimation / reprise - OptiAuto">
        <input type="hidden" name="_next" value="{{ request.origin }}{{ request.path }}#envoye">
      {% endif %}

      <div class="estimation-grid">
        <div class="estimation-form__group">
          <label for="est-email">Email</label>
          <input type="email" id="est-email" name="{% if form_enctype != '' %}_replyto{% else %}contact[email]{% endif %}" class="estimation-form__input">
        </div>
        <div class="estimation-form__group">
          <label for="est-phone">Téléphone <span class="required">*</span></label>
          <input type="tel" id="est-phone" name="{% if form_enctype != '' %}telephone{% else %}contact[phone]{% endif %}" class="estimation-form__input" required>
        </div>
        <div class="estimation-form__group">
          <label for="est-plaque">Immatriculation</label>
          <input type="text" id="est-plaque" name="{% if form_enctype != '' %}immatriculation{% endif %}" class="estimation-form__input" maxlength="20">
        </div>
        <div class="estimation-form__group">
          <label for="est-modele">Modèle</label>
          <input type="text" id="est-modele" name="{% if form_enctype != '' %}modele{% endif %}" class="estimation-form__input" maxlength="120">
        </div>
        <div class="estimation-form__group">
          <label for="est-km">Kilométrage</label>
          <input type="number" id="est-km" name="{% if form_enctype != '' %}kilometrage{% endif %}" class="estimation-form__input" min="0" step="1000">
        </div>
        <div class="estimation-form__group">
          <label for="est-annee">Année</label>
          <input type="number" id="est-annee" name="{% if form_enctype != '' %}annee{% endif %}" class="estimation-form__input" min="1990" max="2030">
        </div>
        <div class="estimation-form__group">
          <label for="est-carburant">Carburant</label>
          <select id="est-carburant" name="{% if form_enctype != '' %}carburant{% endif %}" class="estimation-form__input">
            <option value=""></option>
            <option value="Essence">Essence</option>
            <option value="Diesel">Diesel</option>
            <option value="Hybride">Hybride</option>
            <option value="Hybride rechargeable">Hybride rechargeable</option>
            <option value="Électrique">Électrique</option>
            <option value="Autre">Autre</option>
          </select>
        </div>
        <div class="estimation-form__group">
          <label for="est-boite">Boîte de vitesse</label>
          <select id="est-boite" name="{% if form_enctype != '' %}boite_vitesse{% endif %}" class="estimation-form__input">
            <option value=""></option>
            <option value="Manuelle">Manuelle</option>
            <option value="Automatique">Automatique</option>
            <option value="Semi-automatique">Semi-automatique</option>
            <option value="Robotisée">Robotisée</option>
          </select>
        </div>
      </div>

      <div class="estimation-form__block">
        <label for="est-photos" class="estimation-form__block-label">Photos (formats image, max 5 Mo par fichier)</label>
        <input type="file" id="est-photos" name="{% if form_enctype != '' %}photos{% endif %}" class="estimation-form__input" accept="image/*" multiple {% if form_enctype == '' %}disabled{% endif %}>
        {% if form_enctype != '' %}
          <p class="estimation-form__hint">JPG, PNG, GIF ou WebP. Max 5 Mo par fichier.</p>
        {% else %}
          <p class="estimation-form__hint">Pour envoyer des pièces jointes par e-mail, renseignez l’ID Formspree dans Paramètres du thème &gt; Contact.</p>
        {% endif %}
      </div>

      <div class="estimation-form__submit">
        <button type="submit" class="btn btn--primary btn--lg" id="EstimationSubmitBtn">Envoyer</button>
      </div>

      <div class="estimation-form__success" id="EstimationSuccess" style="display:none;">
        <p><strong>Demande envoyée.</strong> Nous vous recontacterons rapidement à l'adresse contact.optiauto@gmail.com.</p>
      </div>
    </form>
  </div>
</div>

<script>
  (function() {
    var form = document.getElementById('EstimationForm');
    if (!form) return;
    var maxSize = 5 * 1024 * 1024;
    var photosInput = document.getElementById('est-photos');
    if (photosInput) {
      photosInput.addEventListener('change', function() {
        var files = Array.from(this.files || []);
        var invalid = files.filter(function(f) { return f.size > maxSize; });
        if (invalid.length) {
          alert('Certains fichiers dépassent 5 Mo. Veuillez les réduire.');
          this.value = '';
        }
      });
    }
  })();
</script>
