<a href="{{ product.url }}"
   class="vcard {% if product.metafields.custom.sold == true %}vcard--sold{% endif %}"
   data-brand="{{ product.vendor | handleize }}"
   data-model="{{ product.metafields.custom.model | handleize }}"
   data-fuel="{{ product.metafields.custom.fuel | handleize }}"
   data-gearbox="{{ product.metafields.custom.gearbox | handleize }}"
   data-body="{{ product.metafields.custom.body_type | handleize }}"
   data-year="{{ product.metafields.custom.year }}"
   data-km="{{ product.metafields.custom.mileage }}"
   data-seats="{{ product.metafields.custom.seats }}"
   data-critair="{{ product.metafields.custom.critair | handleize }}"
   data-color="{{ product.metafields.custom.color | handleize }}"
   data-transmission="{{ product.metafields.custom.transmission | handleize }}"
   data-power="{{ product.metafields.custom.power_ch }}"
   data-tva="{{ product.metafields.custom.tva_recoverable | handleize }}"
   data-price="{{ product.price }}">

  <div class="vcard__visual">
    {% if product.featured_image != blank %}
      <img src="{{ product.featured_image | image_url: width: 520, height: 340, crop: 'center' }}" alt="{{ product.title | escape }}" loading="lazy" width="520" height="340">
    {% else %}
      <div class="vcard__img-placeholder">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
      </div>
    {% endif %}
    <div class="vcard__badges">
      {% if product.metafields.custom.badge != blank %}
        <span class="vcard__badge">{{ product.metafields.custom.badge }}</span>
      {% endif %}
      {% if product.metafields.custom.guarantee_type == 'constructeur' %}
        <span class="vcard__badge vcard__badge--green">Garantie Constructeur</span>
      {% endif %}
      {% if product.available == false or product.metafields.custom.sold == true %}
        <span class="vcard__badge vcard__badge--red">VENDU</span>
      {% endif %}
    </div>
    <div class="vcard__price-tag">{{ product.price | money_without_trailing_zeros }}</div>
  </div>

  <div class="vcard__info">
    <h3 class="vcard__name">{{ product.vendor }} {{ product.metafields.custom.model | default: product.title }}</h3>

    {% if product.metafields.custom.trim != blank or product.metafields.custom.engine != blank %}
      <p class="vcard__detail">{{ product.metafields.custom.trim }}{% if product.metafields.custom.trim != blank and product.metafields.custom.engine != blank %} · {% endif %}{{ product.metafields.custom.engine }}</p>
    {% endif %}

    <div class="vcard__meta">
      {% if product.metafields.custom.year != blank %}
        <span>{{ product.metafields.custom.year }}</span>
      {% endif %}
      {% if product.metafields.custom.mileage != blank %}
        <span>{{ product.metafields.custom.mileage }} km</span>
      {% endif %}
      {% if product.metafields.custom.fuel != blank %}
        <span>{{ product.metafields.custom.fuel }}</span>
      {% endif %}
      {% if product.metafields.custom.gearbox != blank %}
        <span>{{ product.metafields.custom.gearbox }}</span>
      {% endif %}
    </div>
  </div>
</a>
