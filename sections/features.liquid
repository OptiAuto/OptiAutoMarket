{% comment %}
  Section: Avantages (Contrôle, Garantie, Qualité/Prix)
{% endcomment %}

<div class="features section section--alt">
  <div class="page-width">
    <h2 class="section__title">{{ section.settings.title | default: "Pourquoi nous choisir" }}</h2>
    <p class="section__subtitle">{{ section.settings.subtitle | default: "Achetez une voiture d'occasion sans stress. Nous vous accompagnons de A à Z avec transparence et professionnalisme." }}</p>

    <div class="features__grid">
      <div class="features__card">
        <span class="features__icon">👨‍🔧</span>
        <h3>Véhicules contrôlés</h3>
        <p>Chaque véhicule est inspecté selon un protocole rigoureux. L'état mécanique et l'historique sont vérifiés et documentés de manière transparente.</p>
        {% if section.settings.link1 != blank %}
          <a href="{{ section.settings.link1 }}" class="features__link">En savoir plus →</a>
        {% endif %}
      </div>
      <div class="features__card">
        <span class="features__icon">🚗</span>
        <h3>Rapport qualité-prix garanti</h3>
        <p>Citadine, berline, SUV, utilitaire ou électrique : trouvez le véhicule adapté à vos besoins et à votre budget parmi notre sélection.</p>
        {% if section.settings.link2 != blank %}
          <a href="{{ section.settings.link2 }}" class="features__link">En savoir plus →</a>
        {% endif %}
      </div>
      <div class="features__card">
        <span class="features__icon">👍</span>
        <h3>Garantie constructeur incluse</h3>
        <p>Bénéficiez d'une garantie minimale de 6 mois sur l'ensemble de nos véhicules. Achetez l'esprit tranquille, comme en concession.</p>
        {% if section.settings.link3 != blank %}
          <a href="{{ section.settings.link3 }}" class="features__link">En savoir plus →</a>
        {% endif %}
      </div>
    </div>

    {% if section.settings.cta_text != blank %}
      <div class="features__cta">
        <p>{{ section.settings.cta_text }}</p>
        <a href="/pages/vendre-ma-voiture" class="btn btn--primary">{{ section.settings.cta_button | default: "Estimer et vendre ma voiture" }}</a>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Avantages",
  "class": "section-features",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Bienvenue chez OptiAuto"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Achetez une voiture d'occasion sans stress. On vous accompagne de A à Z !"
    },
    {
      "type": "url",
      "id": "link1",
      "label": "Lien carte 1"
    },
    {
      "type": "url",
      "id": "link2",
      "label": "Lien carte 2"
    },
    {
      "type": "url",
      "id": "link3",
      "label": "Lien carte 3"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texte CTA vente",
      "default": "Vous souhaitez vendre votre voiture ? Nous vous proposons une estimation gratuite et un accompagnement personnalisé."
    },
    {
      "type": "text",
      "id": "cta_button",
      "label": "Texte bouton CTA",
      "default": "Je vends ma voiture"
    }
  ]
}
{% endschema %}
