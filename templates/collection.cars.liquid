{% render 'filters-data' %}

<div class="collection-page">
  <div class="container">

    <div class="collection-header">
      <div>
        <h1 class="collection-header__title">Voitures d'occasion en vente</h1>
        <p class="collection-header__subtitle">Trouvez votre prochaine voiture au meilleur prix, contrôlée et garantie.</p>
      </div>
    </div>

    <div class="collection-layout">

      {%- comment -%} ═══ SIDEBAR FILTRES ═══ {%- endcomment -%}
      <aside class="filters-sidebar" id="FiltersSidebar">
        <div class="filters-sidebar__header">
          <h2 class="filters-sidebar__title">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/><circle cx="8" cy="6" r="2" fill="currentColor"/><circle cx="16" cy="12" r="2" fill="currentColor"/><circle cx="10" cy="18" r="2" fill="currentColor"/></svg>
            Filtres
          </h2>
          <button type="button" class="filters-sidebar__reset" id="ResetFilters">Tout effacer</button>
        </div>

        {%- comment -%} 1. MARQUE {%- endcomment -%}
        <div class="filter-block" data-filter="brand">
          <button class="filter-block__toggle is-open" type="button">
            <span>Marque</span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="filter-block__body">
            <input type="text" class="filter-search" placeholder="Rechercher une marque..." data-search="f-brand">
            <select id="f-brand" class="filter-select" size="6">
              <option value="">Toutes les marques</option>
              {% for b in filter_brands %}
                <option value="{{ b | handleize }}">{{ b }}</option>
              {% endfor %}
            </select>
          </div>
        </div>

        {%- comment -%} 2. MODÈLE {%- endcomment -%}
        <div class="filter-block" data-filter="model">
          <button class="filter-block__toggle is-open" type="button">
            <span>Modèle</span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="filter-block__body">
            <select id="f-model" class="filter-select" size="5" disabled>
              <option value="">Sélectionnez d'abord une marque</option>
            </select>
          </div>
        </div>

        {%- comment -%} 3. CATÉGORIE {%- endcomment -%}
        <div class="filter-block" data-filter="body">
          <button class="filter-block__toggle" type="button">
            <span>Catégorie</span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="filter-block__body" style="display:none;">
            <select id="f-body" class="filter-select" size="6">
              <option value="">Tous les types</option>
              {% for bt in filter_body_types %}
                <option value="{{ bt | handleize }}">{{ bt }}</option>
              {% endfor %}
            </select>
          </div>
        </div>

        {%- comment -%} 4. ANNÉE {%- endcomment -%}
        <div class="filter-block" data-filter="year">
          <button class="filter-block__toggle" type="button">
            <span>Année</span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="filter-block__body" style="display:none;">
            <div class="filter-range">
              <input type="number" id="f-year-min" class="filter-input" placeholder="Min" min="1990" max="2030">
              <span class="filter-range__sep">à</span>
              <input type="number" id="f-year-max" class="filter-input" placeholder="Max" min="1990" max="2030">
            </div>
          </div>
        </div>

        {%- comment -%} 5. KILOMÉTRAGE {%- endcomment -%}
        <div class="filter-block" data-filter="km">
          <button class="filter-block__toggle" type="button">
            <span>Kilométrage</span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="filter-block__body" style="display:none;">
            <div class="filter-range">
              <input type="number" id="f-km-min" class="filter-input" placeholder="Min" min="0" step="5000">
              <span class="filter-range__sep">à</span>
              <input type="number" id="f-km-max" class="filter-input" placeholder="Max" min="0" step="5000">
            </div>
            <div class="filter-shortcuts">
              <button type="button" data-max="f-km-max" data-val="20000">< 20 000</button>
              <button type="button" data-max="f-km-max" data-val="50000">< 50 000</button>
              <button type="button" data-max="f-km-max" data-val="100000">< 100 000</button>
              <button type="button" data-max="f-km-max" data-val="150000">< 150 000</button>
            </div>
          </div>
        </div>

        {%- comment -%} 6. CARBURANT {%- endcomment -%}
        <div class="filter-block" data-filter="fuel">
          <button class="filter-block__toggle" type="button">
            <span>Carburant</span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="filter-block__body" style="display:none;">
            <select id="f-fuel" class="filter-select" size="6">
              <option value="">Tous</option>
              {% for fu in filter_fuels %}
                <option value="{{ fu | handleize }}">{{ fu }}</option>
              {% endfor %}
            </select>
          </div>
        </div>

        {%- comment -%} 7. BOÎTE DE VITESSE {%- endcomment -%}
        <div class="filter-block" data-filter="gearbox">
          <button class="filter-block__toggle" type="button">
            <span>Boîte de vitesse</span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="filter-block__body" style="display:none;">
            <select id="f-gearbox" class="filter-select" size="4">
              <option value="">Toutes</option>
              {% for gb in filter_gearboxes %}
                <option value="{{ gb | handleize }}">{{ gb }}</option>
              {% endfor %}
            </select>
          </div>
        </div>

        {%- comment -%} 8. PRIX {%- endcomment -%}
        <div class="filter-block" data-filter="price">
          <button class="filter-block__toggle is-open" type="button">
            <span>Prix (€)</span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="filter-block__body">
            <div class="filter-range">
              <input type="number" id="f-price-min" class="filter-input" placeholder="Min" min="0" step="500">
              <span class="filter-range__sep">à</span>
              <input type="number" id="f-price-max" class="filter-input" placeholder="Max" min="0" step="500">
            </div>
            <div class="filter-shortcuts">
              <button type="button" data-max="f-price-max" data-val="5000">< 5 000 €</button>
              <button type="button" data-max="f-price-max" data-val="10000">< 10 000 €</button>
              <button type="button" data-max="f-price-max" data-val="15000">< 15 000 €</button>
              <button type="button" data-max="f-price-max" data-val="25000">< 25 000 €</button>
              <button type="button" data-max="f-price-max" data-val="40000">< 40 000 €</button>
            </div>
          </div>
        </div>

        {%- comment -%} 9. NOMBRE DE PLACES {%- endcomment -%}
        <div class="filter-block" data-filter="seats">
          <button class="filter-block__toggle" type="button">
            <span>Nombre de places</span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="filter-block__body" style="display:none;">
            <select id="f-seats" class="filter-select" size="5">
              <option value="">Toutes</option>
              {% for s in filter_seats %}
                <option value="{{ s }}">{{ s }} places</option>
              {% endfor %}
            </select>
          </div>
        </div>

        {%- comment -%} 10. CRIT'AIR {%- endcomment -%}
        <div class="filter-block" data-filter="critair">
          <button class="filter-block__toggle" type="button">
            <span>Crit'Air</span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="filter-block__body" style="display:none;">
            <select id="f-critair" class="filter-select" size="5">
              <option value="">Tous</option>
              {% for ca in filter_critairs %}
                <option value="{{ ca | handleize }}">{{ ca }}</option>
              {% endfor %}
            </select>
          </div>
        </div>

        {%- comment -%} 11. COULEUR {%- endcomment -%}
        <div class="filter-block" data-filter="color">
          <button class="filter-block__toggle" type="button">
            <span>Couleur</span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="filter-block__body" style="display:none;">
            <select id="f-color" class="filter-select" size="6">
              <option value="">Toutes</option>
              {% for co in filter_colors %}
                <option value="{{ co | handleize }}">{{ co }}</option>
              {% endfor %}
            </select>
          </div>
        </div>

        {%- comment -%} 12. PUISSANCE {%- endcomment -%}
        <div class="filter-block" data-filter="power">
          <button class="filter-block__toggle" type="button">
            <span>Puissance (ch)</span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="filter-block__body" style="display:none;">
            <div class="filter-range">
              <input type="number" id="f-power-min" class="filter-input" placeholder="Min ch" min="0" step="10">
              <span class="filter-range__sep">à</span>
              <input type="number" id="f-power-max" class="filter-input" placeholder="Max ch" min="0" step="10">
            </div>
            <div class="filter-shortcuts">
              <button type="button" data-max="f-power-max" data-val="100">< 100 ch</button>
              <button type="button" data-max="f-power-max" data-val="150">< 150 ch</button>
              <button type="button" data-max="f-power-max" data-val="200">< 200 ch</button>
              <button type="button" data-max="f-power-max" data-val="300">< 300 ch</button>
            </div>
          </div>
        </div>

        {%- comment -%} 13. GARANTIE {%- endcomment -%}
        <div class="filter-block" data-filter="guarantee">
          <button class="filter-block__toggle" type="button">
            <span>Garantie</span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="filter-block__body" style="display:none;">
            <select id="f-guarantee" class="filter-select" size="5">
              <option value="">Toutes</option>
              {% for g in filter_guarantees %}
                <option value="{{ g | handleize }}">{{ g }}</option>
              {% endfor %}
            </select>
          </div>
        </div>

        {%- comment -%} 14. TVA RÉCUPÉRABLE {%- endcomment -%}
        <div class="filter-block" data-filter="tva">
          <button class="filter-block__toggle" type="button">
            <span>TVA récupérable</span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="filter-block__body" style="display:none;">
            <select id="f-tva" class="filter-select" size="3">
              <option value="">Indifférent</option>
              {% for t in filter_tva %}
                <option value="{{ t | handleize }}">{{ t }}</option>
              {% endfor %}
            </select>
          </div>
        </div>

        <div class="filters-sidebar__apply">
          <button type="button" class="btn btn--primary btn--lg" id="ApplyFilters" style="width:100%;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            Rechercher
          </button>
        </div>
      </aside>

      {%- comment -%} ═══ ZONE RÉSULTATS ═══ {%- endcomment -%}
      <div class="collection-results">

        <div class="collection-toolbar">
          <div class="collection-toolbar__count" id="ResultsCount">
            {{ collection.products_count }} véhicule{% if collection.products_count > 1 %}s{% endif %}
          </div>
          <div class="collection-toolbar__actions">
            <select id="SortBy" class="filter-select-inline">
              <option value="relevance">Trier par : Pertinence</option>
              <option value="price-asc">Prix croissant</option>
              <option value="price-desc">Prix décroissant</option>
              <option value="date-desc">Plus récents</option>
              <option value="km-asc">Km croissant</option>
              <option value="km-desc">Km décroissant</option>
            </select>
            <button type="button" class="filters-mobile-toggle" id="FiltersMobileToggle">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>
              Filtres
            </button>
          </div>
        </div>

        <div class="vgrid" id="VehicleGrid">
          {% for product in collection.products %}
            {% render 'vehicle-card', product: product %}
          {% else %}
            <p class="vgrid__empty">Aucun véhicule disponible pour le moment.</p>
          {% endfor %}
        </div>

        <div class="vgrid__no-results" id="NoResults" style="display:none;">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <p>Aucun véhicule ne correspond à vos critères.</p>
          <button class="btn btn--ghost" onclick="document.getElementById('ResetFilters').click()">Réinitialiser les filtres</button>
        </div>
      </div>

    </div>
  </div>
</div>
