<section class="features">
  <div class="container">
    <h2 class="section-title section-title--xl">{{ section.settings.title | default: "Véhicules révisés, garantis et au meilleur prix" }}</h2>

    <div class="features-grid">
      {% for block in section.blocks %}
        <div class="feature-card" {{ block.shopify_attributes }}>
          <div class="feature-card__icon">{{ block.settings.icon }}</div>
          <h3 class="feature-card__title">{{ block.settings.title }}</h3>
          <p class="feature-card__desc">{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Avantages",
  "class": "section-features",
  "settings": [
    { "type": "text", "id": "title", "label": "Titre", "default": "Véhicules révisés, garantis et au meilleur prix" },
    { "type": "text", "id": "subtitle", "label": "Sous-titre", "default": "Chaque voiture est soumise à un contrôle rigoureux avant d'être proposée à la vente." }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Avantage",
      "settings": [
        { "type": "text", "id": "icon", "label": "Emoji", "default": "🔍" },
        { "type": "text", "id": "title", "label": "Titre", "default": "Véhicules contrôlés" },
        { "type": "textarea", "id": "text", "label": "Description", "default": "Chaque véhicule fait l'objet d'une inspection mécanique complète de 200 points avant sa mise en vente." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Avantages",
      "blocks": [
        { "type": "feature", "settings": { "icon": "🔍", "title": "Véhicules contrôlés", "text": "Chaque véhicule fait l'objet d'une inspection mécanique complète de 200 points avant sa mise en vente." } },
        { "type": "feature", "settings": { "icon": "🛡️", "title": "Garantie incluse", "text": "Tous nos véhicules sont couverts par une garantie de 6 à 24 mois, pièces et main-d'œuvre." } },
        { "type": "feature", "settings": { "icon": "💰", "title": "Prix transparent", "text": "Nos prix sont fermes, justes et sans frais cachés. Nous nous engageons au meilleur rapport qualité-prix." } },
        { "type": "feature", "settings": { "icon": "🤝", "title": "Accompagnement personnalisé", "text": "Un conseiller dédié vous guide de la sélection du véhicule à la remise des clés." } }
      ]
    }
  ]
}
{% endschema %}
