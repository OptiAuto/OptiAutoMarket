{% comment %}
  Section: Catégories populaires (Citadine, SUV, Berline...)
{% endcomment %}

<div class="categories section">
  <div class="page-width">
    <h2 class="section__title">{{ section.settings.title | default: "Nos catégories les plus recherchées" }}</h2>

    <div class="categories__grid">
      {% for block in section.blocks %}
        {% if block.type == 'category' %}
          <a href="{{ block.settings.link }}" class="categories__card" {{ block.shopify_attributes }}>
            {% if block.settings.icon != blank %}
              <span class="categories__icon">{{ block.settings.icon }}</span>
            {% endif %}
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.description }}</p>
          </a>
        {% endif %}
      {% endfor %}

      {% if section.blocks.size == 0 %}
        {% comment %} Catégories par défaut - style Capcar, La Centrale {% endcomment %}
        <a href="/collections/utilitaire" class="categories__card">
          <span class="categories__icon">🚐</span>
          <h3>Utilitaire</h3>
          <p>Véhicules professionnels pour tous vos déplacements</p>
        </a>
        <a href="/collections/break" class="categories__card">
          <span class="categories__icon">🚗</span>
          <h3>Break</h3>
          <p>Espace de chargement et confort de conduite</p>
        </a>
        <a href="/collections/monospace" class="categories__card">
          <span class="categories__icon">🚙</span>
          <h3>Monospace</h3>
          <p>Idéal pour les familles</p>
        </a>
        <a href="/collections/berline" class="categories__card">
          <span class="categories__icon">🏎️</span>
          <h3>Berline</h3>
          <p>Confort et prestige au quotidien</p>
        </a>
        <a href="/collections/suv" class="categories__card">
          <span class="categories__icon">🛻</span>
          <h3>4x4 et SUV</h3>
          <p>Polyvalence et capacité de chargement</p>
        </a>
        <a href="/collections/citadine" class="categories__card">
          <span class="categories__icon">🚙</span>
          <h3>Citadine</h3>
          <p>Maniabilité et économie en ville</p>
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Catégories",
  "class": "section-categories",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Nos catégories les plus recherchées"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Catégorie",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titre"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lien"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icône (emoji)"
        }
      ]
    }
  ]
}
{% endschema %}
